# Server Configuration
HONEYPOT_PORT=4002
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_NAME=honeypot
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Admin Security
ADMIN_TOKEN=PasswordSuperSegreta
JWT_SECRET=SaaS_JwtSecret_HoneypotSecure2026_ChangeMe
TRUST_PROXY=1
SESSION_SALT=SecureRandomSaltHere_ChangeMeInProduction

# Admin Dashboard (Isolated Server)
ADMIN_PORT=4003
ADMIN_ALLOWED_ORIGIN=http://localhost:5173

# Scalability (Optional Redis)
# Change STORAGE_TYPE to 'redis' to use a distributed cache for IP tracking
STORAGE_TYPE=memory
REDIS_URL=redis://localhost:6379

OPENAI_API_KEY=your-openai-api-key-here
GEMINI_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp