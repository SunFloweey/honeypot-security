{
  "name": "diana-backend",
  "version": "1.0.0",
  "description": "DIANA - Deceptive Infrastructure & Analysis Network Agent",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:admin": "node admin-server.js",
    "start:both": "node server.js & node admin-server.js",
    "dev": "node scripts/kill-port.js 4002 && nodemon server.js",
    "dev:admin": "node scripts/kill-port.js 4003 && nodemon admin-server.js",
    "test": "jest --testTimeout=10000 --detectOpenHandles --forceExit",
    "test:intrusion": "jest tests/intrusion-response.test.js --testTimeout=15000 --detectOpenHandles --forceExit --verbose"
  },
  "keywords": [
    "diana",
    "deceptive-infrastructure",
    "honeypot",
    "security",
    "threat-detection",
    "cybersecurity"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dockerode": "^4.0.9",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.22.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "redis": "^5.10.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^1.0.37",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
